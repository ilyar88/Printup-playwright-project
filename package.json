  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "allure-commandline": "^2.37.0",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@applitools/eyes-playwright": "1.42.2",
    "@babel/parser": "^7.29.2",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.3.1",
    "node-autoit-koffi": "^1.0.7",
    "openai": "^6.33.0",
    "recast": "^0.23.11",
    "xlsx": "^0.18.5"
  }
